---
import { Image } from "astro:assets";
import bgImage from "../../../public/images/landing-page-bg.jpg";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import type { PortfolioContent } from "../../data/portfolio";

interface Props {
  content: PortfolioContent;
}

const { content } = Astro.props;
const heroContactLine = [
  content.identity.name,
  content.identity.email,
  content.identity.phone,
]
  .filter(Boolean)
  .join(" · ");
---

<header
  id="hero"
  class="section soft-fade-in"
  style="border-top:0;min-height:100svh;display:flex;align-items:center;position:relative;overflow:hidden;"
>
  <!-- Cursor spotlight -->
  <div id="hero-spotlight" class="hero-spotlight"></div>

  <div class="animated-bg">
    <Image
      src={bgImage}
      alt="Background abstract liquid"
      class="bg-img-motion"
    />
  </div>

  <div
    class="container"
    style="display:grid;gap:18px;text-align:center;position:relative;z-index:2;"
  >
    <div
      class="hero-fade-down"
      style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;animation-delay:0.8s;"
    >
      <div class="site-mark">adnan.</div>
      <div
        style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;justify-content:flex-end;"
      >
        <nav class="hero-nav">
          <a href="#about">{content.nav.about}</a>
          <a href="#experience">{content.nav.experience}</a>
          <a href="#projects">{content.nav.projects}</a>
          <a href="#contact">{content.nav.contact}</a>
        </nav>
        <LanguageSwitcher locale={content.locale} />
      </div>
    </div>
    <div class="kicker hero-fade-down" style="animation-delay:0.9s;">
      {content.identity.role} · {content.identity.location}
    </div>
    <h1 class="hero-scale-in" style="font-size:clamp(52px,9vw,108px);">
      {content.hero.heading}
    </h1>
    <p
      class="hero-fade-up"
      style="max-width:760px;margin:0 auto;color:var(--muted);font-size:22px;font-weight:300;animation-delay:1.1s;"
    >
      {content.hero.summary}
    </p>
    <p
      class="hero-fade-up"
      style="margin:0;color:var(--soft);font-size:12px;text-transform:uppercase;letter-spacing:.06em;animation-delay:1.2s;"
    >
      {heroContactLine}
    </p>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-hint" aria-hidden="true">
    <span class="scroll-hint-line"></span>
    <span class="scroll-hint-label">scroll</span>
  </div>
</header>

<style>
  .hero-spotlight {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(
      600px circle at 50% 50%,
      rgba(196, 98, 45, 0.06),
      transparent 70%
    );
    transition: background 0.1s ease;
  }

  .site-mark {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.02em;
    transition: color 0.2s ease;
  }
  .site-mark:hover {
    color: var(--accent);
  }

  .hero-nav {
    display: flex;
    gap: 20px;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-nav a {
    color: var(--muted);
    text-decoration: none;
    position: relative;
    padding-bottom: 3px;
    transition: color 0.25s ease, transform 0.25s ease;
  }

  .hero-nav a:hover {
    color: var(--accent);
    transform: translateY(-3px);
  }

  .animated-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    overflow: hidden;
  }

  .animated-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform-origin: center;
    will-change: transform, opacity;
    animation: bg-fade-in 2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards,
      bg-pan-zoom 25s ease-in-out infinite alternate;
    opacity: 0;
  }

  @keyframes bg-fade-in {
    0% {
      opacity: 0;
      transform: scale(1.15);
    }
    100% {
      opacity: 0.15;
      transform: scale(1.1);
    }
  }

  @keyframes bg-pan-zoom {
    0% {
      transform: scale(1.1) translate(0, 0);
    }
    33% {
      transform: scale(1.15) translate(1%, -1%);
    }
    66% {
      transform: scale(1.12) translate(-1%, 1%);
    }
    100% {
      transform: scale(1.15) translate(0, 0);
    }
  }

  .container {
    position: relative;
    z-index: 2;
  }

  .pause-animation .animated-bg img {
    animation-play-state: paused !important;
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 3;
    animation: scroll-hint-bob 2s ease-in-out infinite;
    animation-delay: 1.5s;
    opacity: 0;
    animation-fill-mode: forwards;
  }

  @keyframes scroll-hint-bob {
    0% {
      opacity: 0;
      transform: translateX(-50%) translateY(0);
    }
    20% {
      opacity: 1;
    }
    80% {
      opacity: 1;
      transform: translateX(-50%) translateY(8px);
    }
    100% {
      opacity: 0;
      transform: translateX(-50%) translateY(8px);
    }
  }

  .scroll-hint-line {
    display: block;
    width: 1px;
    height: 28px;
    background: linear-gradient(to bottom, var(--accent), transparent);
  }

  .scroll-hint-label {
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.7;
  }

  /* Entrance Animations */
  .hero-scale-in {
    opacity: 0;
    transform: scale(0.85);
    animation: hero-scale-in 1.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 0.3s;
  }

  @keyframes hero-scale-in {
    0% {
      opacity: 0;
      transform: scale(0.85);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  .hero-fade-down {
    opacity: 0;
    transform: translateY(-20px);
    animation: hero-fade-y 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-fade-y 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes hero-fade-y {
    0% {
      opacity: 0;
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  if (typeof window !== "undefined") {
    // Pause heavy animation when off-screen
    const hero = document.getElementById("hero");
    if (hero) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) {
              hero.classList.add("pause-animation");
            } else {
              hero.classList.remove("pause-animation");
            }
          });
        },
        { threshold: 0.01 }
      );
      observer.observe(hero);
    }

    // Cursor spotlight
    const spotlight = document.getElementById("hero-spotlight");
    if (hero && spotlight) {
      hero.addEventListener("mousemove", (e) => {
        const rect = hero.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        spotlight.style.background = `radial-gradient(600px circle at ${x}px ${y}px, rgba(196,98,45,0.07), transparent 65%)`;
      });
      hero.addEventListener("mouseleave", () => {
        spotlight.style.background =
          "radial-gradient(600px circle at 50% 50%, rgba(196,98,45,0.04), transparent 70%)";
      });
    }
  }
</script>
