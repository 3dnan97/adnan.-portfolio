---
import type { PortfolioContent } from "../../data/portfolio";

interface Props {
  content: PortfolioContent;
}

const { content } = Astro.props;
---

<section id="skills" class="section reveal" style="background:var(--bg-alt);">
  <div class="container" style="display:grid;gap:20px;width:100%;">
    <div class="stagger-child">
      <div class="kicker">{content.sectionLabels.skills}</div>
      <h2 style="font-size:clamp(34px,6vw,58px);margin-top:8px;">
        {content.skills.heading}
      </h2>
    </div>
    <div class="skills-grid">
      {
        content.skills.categories.map((category) => (
          <article class="skill-card motion-lift stagger-child">
            <div class="skill-card-header">
              <h3>{category.title}</h3>
              <span class="skill-count">{category.items.length}</span>
            </div>
            <div class="chip-row">
              {category.items.map((item) => (
                <span class="chip">{item}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
    align-items: stretch;
  }

  .skill-card {
    border: 1px solid var(--line);
    background: var(--bg);
    padding: 18px;
    display: grid;
    gap: 14px;
    align-content: start;
    position: relative;
    overflow: hidden;
  }

  .skill-card-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }

  .skill-card-header h3 {
    font-size: 18px;
    line-height: 1.2;
  }

  .skill-count {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    background: var(--accent);
    padding: 2px 7px;
    border-radius: 100px;
    flex-shrink: 0;
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
</style>
